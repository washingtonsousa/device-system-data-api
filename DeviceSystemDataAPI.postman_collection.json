{
  "info": {
    "name": "DeviceSystemDataAPI",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "GET devices",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/DeviceData?page=1&page_size=10",
          "host": ["{{baseUrl}}"],
          "path": ["api", "DeviceData"],
          "query": [
            { "key": "page", "value": "1" },
            { "key": "page_size", "value": "10" },
            { "key": "brand", "value": "Apple", "disabled": true },
            { "key": "state", "value": "available", "disabled": true },
            { "key": "deviceId", "value": "", "disabled": true }
          ]
        }
      },
      "response": []
    },
    {
      "name": "GET device by id",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/DeviceData/:id",
          "host": ["{{baseUrl}}"],
          "path": ["api", "DeviceData", ":id"],
          "variable": [
            { "key": "id", "value": "" }
          ]
        }
      },
      "response": []
    },
    {
      "name": "POST device",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Galaxy S24\",\n  \"brand\": \"Samsung\",\n  \"state\": \"available\"\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": {
          "raw": "{{baseUrl}}/api/DeviceData",
          "host": ["{{baseUrl}}"],
          "path": ["api", "DeviceData"]
        }
      },
      "response": []
    },
    {
      "name": "PUT device",
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Iphone 15 Pro\",\n  \"brand\": \"Apple\",\n  \"state\": \"in-use\"\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": {
          "raw": "{{baseUrl}}/api/DeviceData/:id",
          "host": ["{{baseUrl}}"],
          "path": ["api", "DeviceData", ":id"],
          "variable": [
            { "key": "id", "value": "" }
          ]
        }
      },
      "response": []
    },
    {
      "name": "PATCH device state",
      "request": {
        "method": "PATCH",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"state\": \"inactive\"\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": {
          "raw": "{{baseUrl}}/api/DeviceData/:id",
          "host": ["{{baseUrl}}"],
          "path": ["api", "DeviceData", ":id"],
          "variable": [
            { "key": "id", "value": "" }
          ]
        }
      },
      "response": []
    },
    {
      "name": "DELETE device",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/DeviceData/:id",
          "host": ["{{baseUrl}}"],
          "path": ["api", "DeviceData", ":id"],
          "variable": [
            { "key": "id", "value": "" }
          ]
        }
      },
      "response": []
    }
  ]
}
